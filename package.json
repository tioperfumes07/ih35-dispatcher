{
  "name": "ih35-dispatch-v3-starter",
  "version": "0.1.0",
  "description": "IH35 dispatch / ERP operations hub — Express app with Rule 0 + HTTP smoke (npm run qa:automated / qa:isolated run smoke-gate-paths-sync, rule0:check, system-smoke).",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:test": "node scripts/db-test.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "smoke": "node scripts/system-smoke.mjs",
    "smoke:gate-sync": "node scripts/smoke-gate-paths-sync.mjs",
    "qa:automated": "npm run smoke:gate-sync && node scripts/rule-zero-agent-b-check.mjs --skip-release-tip && npm run smoke",
    "qa:isolated": "node scripts/qa-with-server.mjs",
    "test": "npm run rule0:check",
    "rule0:check": "node scripts/rule-zero-agent-b-check.mjs",
    "report:erp": "node scripts/generate-erp-progress-report.mjs"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1"
  }
}
