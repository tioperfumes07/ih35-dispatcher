{
  "name": "ih35-dispatch-v3-starter",
  "version": "0.1.0",
  "description": "IH35 dispatch / ERP operations hub — Express app with Rule 0 + HTTP smoke (qa:automated: gate-sync, rule0, smoke, unit tests; qa:isolated: temp server + same + unit tests when dev port is busy).",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prestart": "node scripts/ensure-fleet-reports-dist.mjs",
    "start": "node server.js",
    "dev": "node scripts/dev-stack.mjs",
    "dev:server-only": "node scripts/ensure-fleet-reports-dist.mjs && node --watch server.js",
    "dev:fleet": "npm --prefix apps/fleet-reports-hub run dev",
    "dev:fleet:api": "npm --prefix apps/fleet-reports-hub run dev:api",
    "build:fleet": "VITE_BASE=/fleet-reports/ npm --prefix apps/fleet-reports-hub run build && rm -rf public/fleet-reports && mkdir -p public/fleet-reports && cp -R apps/fleet-reports-hub/dist/. public/fleet-reports/",
    "dev:fresh": "npm run build:fleet && node scripts/dev-stack.mjs",
    "db:test": "node scripts/db-test.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:ensure-support": "node scripts/ensure-support-tables.mjs",
    "smoke": "node scripts/system-smoke.mjs",
    "smoke:gate-sync": "node scripts/smoke-gate-paths-sync.mjs",
    "test:name-mgmt": "node --test tests/name-management-erp.test.mjs",
    "test:fleet-mileage": "node --test tests/fleet-mileage-settings.test.mjs",
    "test:integrity-meta": "node --test tests/integrity-engine-export-meta.test.mjs",
    "test:playwright": "playwright test",
    "qa:automated": "npm run smoke:gate-sync && node scripts/rule-zero-agent-b-check.mjs --skip-release-tip && npm run smoke && npm run test:name-mgmt && npm run test:fleet-mileage",
    "qa:isolated": "node scripts/qa-with-server.mjs",
    "test": "npm run rule0:check",
    "rule0:check": "node scripts/rule-zero-agent-b-check.mjs",
    "report:erp": "node scripts/generate-erp-progress-report.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "xlsx": "npm:@e965/xlsx@^0.20.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1"
  }
}
