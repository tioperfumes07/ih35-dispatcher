<!DOCTYPE html>
<html>
<head>
  <title>IH35 Dispatcher AI</title>
  <style>
    body { font-family: Arial; padding: 20px; }
    .box { border: 1px solid #ddd; padding: 10px; margin-bottom: 10px; border-radius: 8px; }
    .bad { color: red; font-weight: bold; }
    .ok { color: green; font-weight: bold; }
    .warn { color: orange; font-weight: bold; }
    .title { font-size: 18px; font-weight: bold; margin-bottom: 12px; }
    textarea { width: 460px; height: 90px; }
    .row { margin-bottom: 14px; }
    #mapBox { width: 100%; max-width: 900px; height: 320px; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 14px; background: #fafafa; }
    svg { width: 100%; height: 100%; display: block; }
    input[type="text"] { padding: 6px; width: 220px; }
    button { padding: 6px 10px; margin-right: 6px; }
  </style>
</head>
<body>

<h1>IH35 Dispatcher AI</h1>

<div class="row">
  <button onclick="loadFleet()">Load Fleet</button>
  <button onclick="refreshFleetOnly()">Refresh Fleet</button>
  <button onclick="runAppTest()">Run App Test</button>
</div>

<div id="testPanel"></div>

<div class="row">
  Search Unit:
  <input id="unitSearch" type="text" placeholder="T159" oninput="renderFleet()">
  <label><input id="showFuelNowOnly" type="checkbox" onchange="renderFleet()"> Show FUEL NOW only</label>
</div>

<div class="row">
  Truck:
  <select id="truck"></select>
</div>

<div class="row">
  <b>Outbound / northbound stops</b><br>
  <textarea id="outboundStops" placeholder="San Antonio, TX
Dallas, TX
Chicago, IL"></textarea>
</div>

<div class="row">
  <b>Empty reposition / pickup stops</b><br>
  <textarea id="repositionStops" placeholder="Joliet, IL
St. Louis, MO"></textarea>
</div>

<div class="row">
  <b>Return / southbound stops</b><br>
  <textarea id="returnStops" placeholder="Memphis, TN
Houston, TX
Laredo, TX"></textarea>
</div>

<div class="row">
  <input type="file" id="csv">
  <button onclick="run()">Recommend Fuel</button>
</div>

<div id="fleetSummary"></div>
<div id="fleet"></div>
<div id="mapBox"></div>
<div id="output"></div>

<script>
const LAREDO = { lat: 27.53, lon: -99.48, text: 'Laredo, TX (fallback home base)' };
const EXPENSIVE_STATES = new Set(['NY','NJ','CT','MA','CA','PA','WA','OR']);
const SHIFT_TARGET_MILES = 750;
const RESERVE_GALLONS = 35;
const PLANNING_MPG = 6.5;

let trucks = [];
let fuelStops = [];
let route = [];
let totalMiles = 0;
let totalDurationHours = 0;
let hosRows = [];
let assignmentRows = [];

function tank(name) { return name === 'T169' ? 80 : 120; }
function gallons(name, fuelPercent) { return tank(name) * (fuelPercent / 100); }
function maxReachMiles(name, fuelPercent) { return Math.max(0, gallons(name, fuelPercent) - RESERVE_GALLONS) * PLANNING_MPG; }
function hosReach() { return 375; }
function shiftGallonsNeeded() { return (SHIFT_TARGET_MILES / PLANNING_MPG) + RESERVE_GALLONS; }
function gallonsNeededNow(name, fuelPercent) { return Math.max(0, shiftGallonsNeeded() - gallons(name, fuelPercent)); }
function coverageMilesAfterFuel(totalGallons) { return Math.max(0, totalGallons - RESERVE_GALLONS) * PLANNING_MPG; }

function dist(lat1, lon1, lat2, lon2) {
  const R = 3959;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;
  const a =
    Math.sin(dLat / 2) ** 2 +
    Math.cos(lat1 * Math.PI / 180) *
    Math.cos(lat2 * Math.PI / 180) *
    Math.sin(dLon / 2) ** 2;
  return 2 * R * Math.asin(Math.sqrt(a));
}

function shortLocation(text) {
  if (!text) return 'Unknown';
  const parts = String(text).split(',').map(s => s.trim()).filter(Boolean);
  if (parts.length >= 2) return `${parts[parts.length - 2]}, ${parts[parts.length - 1]}`;
  return text;
}

function fmtHours(h) {
  if (h == null || Number.isNaN(h)) return 'N/A';
  return `${h.toFixed(1)} hrs`;
}
function msToHours(ms) {
  if (ms == null || Number.isNaN(ms)) return null;
  return ms / 1000 / 3600;
}
function secondsToHours(sec) {
  if (sec == null || Number.isNaN(sec)) return null;
  return sec / 3600;
}
function fmtMiles(m) {
  if (m == null || Number.isNaN(m)) return 'N/A';
  return `${m.toFixed(0)} mi`;
}
function fmtGallons(g) {
  if (g == null || Number.isNaN(g)) return 'N/A';
  return `${g.toFixed(1)} gal`;
}
function fmtEta(hours) {
  if (hours == null || Number.isNaN(hours)) return 'N/A';
  const now = new Date();
  const eta = new Date(now.getTime() + hours * 3600 * 1000);
  return eta.toLocaleString();
}

function statusForTruck(name, fuel) {
  const reach = Math.min(maxReachMiles(name, fuel), hosReach());
  if (gallons(name, fuel) <= RESERVE_GALLONS || reach < 75) return { text: 'FUEL NOW', cls: 'bad', rank: 0 };
  if (gallonsNeededNow(name, fuel) > 0) return { text: 'FUEL FOR SHIFT', cls: 'warn', rank: 1 };
  return { text: 'WAIT', cls: 'ok', rank: 2 };
}

function scoreStop(stop, truckName, currentGallons) {
  const gallonsToFull = Math.max(0, tank(truckName) - currentGallons);
  const coverageAfterFuel = coverageMilesAfterFuel(currentGallons + gallonsToFull);

  let score = stop.price;
  score += stop.off * 0.02;
  score += stop.mile * 0.001;

  if (!EXPENSIVE_STATES.has((stop.state || '').toUpperCase())) score -= 0.12;
  else score += 0.20;

  if (coverageAfterFuel >= SHIFT_TARGET_MILES) score -= 0.20;
  else if (coverageAfterFuel >= 600) score -= 0.08;

  if (stop.price < 5.20) score -= 0.10;
  if (stop.price < 5.00) score -= 0.15;

  stop.recommendedBuy = gallonsToFull;
  stop.coverageAfterFuel = coverageAfterFuel;
  stop.estimatedCost = gallonsToFull * stop.price;
  stop.score = score;
  return stop;
}

function parseHosRow(row) {
  return {
    driveAvail:
      msToHours(row.driveTimeRemainingMs) ??
      secondsToHours(row.driveTimeRemainingSeconds) ??
      msToHours(row.driveRemainingMs) ??
      secondsToHours(row.driveRemainingSeconds) ?? null,
    shiftAvail:
      msToHours(row.shiftTimeRemainingMs) ??
      secondsToHours(row.shiftTimeRemainingSeconds) ??
      msToHours(row.shiftRemainingMs) ??
      secondsToHours(row.shiftRemainingSeconds) ?? null,
    cycleAvail:
      msToHours(row.cycleTimeRemainingMs) ??
      secondsToHours(row.cycleTimeRemainingSeconds) ?? null,
    breakAvail:
      msToHours(row.breakTimeRemainingMs) ??
      secondsToHours(row.breakTimeRemainingSeconds) ?? null,
    resetAvail:
      msToHours(row.timeUntilResetMs) ??
      secondsToHours(row.timeUntilResetSeconds) ??
      msToHours(row.restartTimeRemainingMs) ??
      secondsToHours(row.restartTimeRemainingSeconds) ?? null,
    hoursDriven:
      msToHours(row.driveTimeUsedMs) ??
      secondsToHours(row.driveTimeUsedSeconds) ??
      msToHours(row.driveUsedMs) ??
      secondsToHours(row.driveUsedSeconds) ?? null,
    milesDriven:
      Number(row.milesDriven ?? row.distanceMiles ?? row.drivingMiles ?? NaN)
  };
}

function findHosForTruck(truck) {
  if (!hosRows.length) return {
    driveAvail: null, shiftAvail: null, cycleAvail: null, breakAvail: null,
    resetAvail: null, hoursDriven: null, milesDriven: null
  };

  const row =
    hosRows.find(r => String(r.vehicleName || r.name || '').trim() === truck.name) ||
    hosRows.find(r => String(r.vehicleId || r.assetId || r.id || '') === String(truck.id)) ||
    hosRows[0];

  return parseHosRow(row);
}

async function j(url) { return await (await fetch(url)).json(); }

async function geocodeOne(place) {
  const res = await j('/api/geocode?q=' + encodeURIComponent(place));
  if (!res || !res[0]) throw new Error('Could not geocode: ' + place);
  return res[0];
}

function drawRouteMap(routeCoords, truck) {
  const box = document.getElementById('mapBox');
  if (!routeCoords.length) { box.innerHTML = ''; return; }

  const xs = routeCoords.map(p => p[0]);
  const ys = routeCoords.map(p => p[1]);
  const minX = Math.min(...xs), maxX = Math.max(...xs);
  const minY = Math.min(...ys), maxY = Math.max(...ys);
  const width = 900, height = 320, pad = 20;

  function project(lon, lat) {
    const x = pad + ((lon - minX) / Math.max(0.0001, maxX - minX)) * (width - pad * 2);
    const y = height - pad - ((lat - minY) / Math.max(0.0001, maxY - minY)) * (height - pad * 2);
    return [x, y];
  }

  const path = routeCoords.map((p, i) => {
    const [x, y] = project(p[0], p[1]);
    return `${i === 0 ? 'M' : 'L'} ${x} ${y}`;
  }).join(' ');

  const [sx, sy] = project(routeCoords[0][0], routeCoords[0][1]);
  const [ex, ey] = project(routeCoords[routeCoords.length - 1][0], routeCoords[routeCoords.length - 1][1]);

  box.innerHTML = `
    <svg viewBox="0 0 ${width} ${height}">
      <rect x="0" y="0" width="${width}" height="${height}" fill="#fafafa"></rect>
      <path d="${path}" fill="none" stroke="#2563eb" stroke-width="3"></path>
      <circle cx="${sx}" cy="${sy}" r="6" fill="#16a34a"></circle>
      <circle cx="${ex}" cy="${ey}" r="6" fill="#dc2626"></circle>
      <text x="${sx + 8}" y="${sy - 8}" font-size="12">Start: ${truck.name}</text>
      <text x="${ex + 8}" y="${ey - 8}" font-size="12">End</text>
    </svg>
  `;
}

function selectTruck(name) {
  document.getElementById('truck').value = name;
}

function renderFleet() {
  const search = document.getElementById('unitSearch').value.trim().toUpperCase();
  const fuelNowOnly = document.getElementById('showFuelNowOnly').checked;

  const display = trucks
    .map(t => ({ ...t, status: statusForTruck(t.name, t.fuel) }))
    .filter(t => !search || t.name.toUpperCase().includes(search))
    .filter(t => !fuelNowOnly || t.status.text === 'FUEL NOW')
    .sort((a, b) => {
      if (a.status.rank !== b.status.rank) return a.status.rank - b.status.rank;
      return gallons(a.name, a.fuel) - gallons(b.name, b.fuel);
    });

  const countFuelNow = trucks.filter(t => statusForTruck(t.name, t.fuel).text === 'FUEL NOW').length;
  const countShift = trucks.filter(t => statusForTruck(t.name, t.fuel).text === 'FUEL FOR SHIFT').length;
  const countWait = trucks.filter(t => statusForTruck(t.name, t.fuel).text === 'WAIT').length;

  document.getElementById('fleetSummary').innerHTML = `
    <div class="box">
      <b>Fleet Summary</b><br>
      FUEL NOW: ${countFuelNow} |
      FUEL FOR SHIFT: ${countShift} |
      WAIT: ${countWait}
    </div>
  `;

  let html = '';
  display.forEach(t => {
    const reach = Math.min(maxReachMiles(t.name, t.fuel), hosReach());
    html += `<div class="box">
      <b>${t.name}</b> — ${t.shortLocation}<br>
      Fuel: ${t.fuel}% (${fmtGallons(gallons(t.name, t.fuel))} left)<br>
      Drive Available: ${fmtHours(t.hos.driveAvail)}<br>
      Hours Driven: ${fmtHours(t.hos.hoursDriven)}<br>
      Miles Driven: ${fmtMiles(t.hos.milesDriven)}<br>
      Reset In: ${fmtHours(t.hos.resetAvail)}<br>
      Reach: ${reach.toFixed(0)} miles<br>
      Status: <span class="${t.status.cls}">${t.status.text}</span><br><br>
      <button onclick="selectTruck('${t.name}')">Use this truck</button>
    </div>`;
  });

  document.getElementById('fleet').innerHTML = html;
}

async function loadFleet() {
  const vehicles = (await j('/api/samsara/vehicles')).data || [];
  const live = (await j('/api/samsara/live')).data || [];
  const hosRes = await j('/api/samsara/hos');
  const assignmentsRes = await j('/api/samsara/assignments');

  hosRows = hosRes.data || hosRes.results || hosRes.rows || (Array.isArray(hosRes) ? hosRes : []);
  assignmentRows = assignmentsRes.data || assignmentsRes.results || (Array.isArray(assignmentsRes) ? assignmentsRes : []);

  const fuelMap = {};
  const locationMap = {};
  const gpsMap = {};

  live.forEach(x => {
    if (x.fuelPercent?.value != null) fuelMap[x.id] = x.fuelPercent.value;
    if (x.gps?.latitude != null && x.gps?.longitude != null) gpsMap[x.id] = { lat: x.gps.latitude, lon: x.gps.longitude };

    const locText =
      x.gps?.reverseGeo?.formattedLocation ||
      x.gps?.address?.name ||
      x.locationText ||
      '';

    if (locText) locationMap[x.id] = locText;
  });

  const seen = new Set();

  trucks = vehicles.filter(v => {
    const m = String(v.name).match(/^T(\d+)/);
    if (!m) return false;
    const n = Number(m[1]);
    if (n < 139 || n > 178) return false;
    if (seen.has(v.name)) return false;
    seen.add(v.name);
    return true;
  }).map(v => {
    let lat = gpsMap[v.id]?.lat || v.gps?.latitude || v.location?.latitude || 0;
    let lon = gpsMap[v.id]?.lon || v.gps?.longitude || v.location?.longitude || 0;
    let locationText = locationMap[v.id] || v.gps?.reverseGeo?.formattedLocation || v.locationText || '';

    if (!lat || !lon) {
      lat = LAREDO.lat;
      lon = LAREDO.lon;
      locationText = LAREDO.text;
    }

    return {
      id: v.id,
      name: v.name,
      fuel: fuelMap[v.id] ?? 50,
      lat,
      lon,
      locationText,
      shortLocation: shortLocation(locationText),
      hos: findHosForTruck({ id: v.id, name: v.name })
    };
  });

  const select = document.getElementById('truck');
  select.innerHTML = '';
  trucks.forEach(t => select.innerHTML += `<option>${t.name}</option>`);

  renderFleet();
}

function refreshFleetOnly() {
  loadFleet();
}

document.getElementById('csv').addEventListener('change', async e => {
  const file = e.target.files[0];
  if (!file) return;

  const text = await file.text();
  const lines = text.split('\n').filter(Boolean);
  const headers = lines[0].split(',');

  fuelStops = lines.slice(1).map(line => {
    const cols = line.split(',');
    const row = {};
    headers.forEach((h, i) => row[h.trim()] = cols[i]);

    return {
      store: row['Loves Store No.'],
      city: row['City'],
      state: row['State'],
      price: Number(row['Best Discounted Price']),
      lat: Number(row['Latitude']),
      lon: Number(row['Longitude'])
    };
  }).filter(s => s.price && s.lat && s.lon);
});

async function buildSettlementRoute(truck) {
  const outbound = document.getElementById('outboundStops').value.split('\n').map(s => s.trim()).filter(Boolean);
  const reposition = document.getElementById('repositionStops').value.split('\n').map(s => s.trim()).filter(Boolean);
  const returning = document.getElementById('returnStops').value.split('\n').map(s => s.trim()).filter(Boolean);

  const allStops = [...outbound, ...reposition, ...returning];
  if (!allStops.length) {
    alert('Enter at least one trip stop');
    return false;
  }

  const coords = [`${truck.lon},${truck.lat}`];
  const geocoded = [];

  for (const stop of allStops) {
    const geo = await geocodeOne(stop);
    coords.push(`${geo.lon},${geo.lat}`);
    geocoded.push({ label: stop, lat: Number(geo.lat), lon: Number(geo.lon) });
  }

  const routeRes = await j('/api/route?coords=' + encodeURIComponent(coords.join(';')));
  totalMiles = routeRes.routes[0].distance / 1609;
  totalDurationHours = (routeRes.routes[0].duration || 0) / 3600;
  route = routeRes.routes[0].geometry.coordinates.filter((_, i) => i % 25 === 0);

  drawRouteMap(route, truck);

  function legMiles(points) {
    if (!points.length) return 0;
    let prev = { lat: truck.lat, lon: truck.lon };
    let total = 0;
    for (const p of points) {
      total += dist(prev.lat, prev.lon, p.lat, p.lon);
      prev = p;
    }
    return total;
  }

  const outboundGeo = geocoded.slice(0, outbound.length);
  const repositionGeo = geocoded.slice(outbound.length, outbound.length + reposition.length);
  const returnGeo = geocoded.slice(outbound.length + reposition.length);

  return {
    outbound,
    reposition,
    returning,
    outboundMiles: legMiles(outboundGeo),
    repositionMiles: legMiles(repositionGeo),
    returnMiles: legMiles(returnGeo)
  };
}

async function run() {
  const name = document.getElementById('truck').value;
  const truck = trucks.find(x => x.name === name);

  if (!truck || !fuelStops.length) {
    document.getElementById('output').innerHTML = '<div class="box">Missing data</div>';
    return;
  }

  const trip = await buildSettlementRoute(truck);
  if (!trip) return;

  const maxReach = Math.min(maxReachMiles(name, truck.fuel), hosReach());
  const currentGallons = gallons(name, truck.fuel);
  const shiftNeed = gallonsNeededNow(name, truck.fuel);
  const truckStatus = statusForTruck(name, truck.fuel);

  let enriched = fuelStops.map(s => {
    let best = 999, idx = 0;
    for (let i = 0; i < route.length; i++) {
      const p = route[i];
      const d = dist(s.lat, s.lon, p[1], p[0]);
      if (d < best) {
        best = d; idx = i;
        if (best < 1) break;
      }
    }
    return { ...s, off: best, mile: (idx / route.length) * totalMiles };
  });

  let candidates = enriched.filter(s => s.off < 30).filter(s => s.mile <= maxReach);
  if (!candidates.length) {
    candidates = enriched.filter(s => s.off < 30).sort((a, b) => a.mile - b.mile).slice(0, 10);
  }

  candidates = candidates.map(s => scoreStop(s, name, currentGallons)).sort((a, b) => a.score - b.score).slice(0, 10);

  const best = candidates[0];
  let actionText = 'WAIT FOR CHEAPER STATE';
  if (truckStatus.text === 'FUEL NOW') actionText = 'FILL HERE';
  else if (shiftNeed > 0) actionText = 'BUY FOR SHIFT';
  else if (best && !EXPENSIVE_STATES.has((best.state || '').toUpperCase())) actionText = 'FILL HERE';

  let html = `<div class="box">
    <div class="title">${name} — ${truck.shortLocation}</div>
    <b>Status:</b> <span class="${truckStatus.cls}">${truckStatus.text}</span><br>
    <b>Recommended Action:</b> ${actionText}<br>
    <b>Outbound:</b> ${trip.outbound.length ? trip.outbound.join(' → ') : 'None'}<br>
    <b>Reposition:</b> ${trip.reposition.length ? trip.reposition.join(' → ') : 'None'}<br>
    <b>Return:</b> ${trip.returning.length ? trip.returning.join(' → ') : 'None'}<br>
    <b>Precise Address:</b> ${truck.locationText}<br>
    <b>Fuel:</b> ${truck.fuel}% (${fmtGallons(currentGallons)} left)<br>
    <b>Drive Available:</b> ${fmtHours(truck.hos.driveAvail)}<br>
    <b>Shift Available:</b> ${fmtHours(truck.hos.shiftAvail)}<br>
    <b>Cycle Available:</b> ${fmtHours(truck.hos.cycleAvail)}<br>
    <b>Hours Driven:</b> ${fmtHours(truck.hos.hoursDriven)}<br>
    <b>Miles Driven:</b> ${fmtMiles(truck.hos.milesDriven)}<br>
    <b>Next Reset In:</b> ${fmtHours(truck.hos.resetAvail)}<br>
    <b>Gallons Needed For Shift:</b> ${fmtGallons(shiftNeed)}<br>
    <b>Outbound Miles:</b> ${trip.outboundMiles.toFixed(0)}<br>
    <b>Reposition Miles:</b> ${trip.repositionMiles.toFixed(0)}<br>
    <b>Return Miles:</b> ${trip.returnMiles.toFixed(0)}<br>
    <b>Total Settlement Miles:</b> ${totalMiles.toFixed(0)}<br>
    <b>Approx ETA:</b> ${fmtEta(totalDurationHours)}<br>
    <b>Route Time:</b> ${fmtHours(totalDurationHours)}<br>
    <b>Max Reach:</b> ${maxReach.toFixed(0)} miles
  </div>`;

  if (!candidates.length) {
    html += `<div class="box">NO STOPS FOUND</div>`;
    document.getElementById('output').innerHTML = html;
    return;
  }

  html += `<div class="box">
    <b>BEST RECOMMENDED STOP</b><br>
    ${best.store} - ${best.city}, ${best.state}<br>
    Price: $${best.price.toFixed(3)}<br>
    Approx Route Mile: ${best.mile.toFixed(0)}<br>
    Off Route: ${best.off.toFixed(1)} miles<br>
    Buy Gallons: ${fmtGallons(best.recommendedBuy)}<br>
    Coverage After Fuel: ${best.coverageAfterFuel.toFixed(0)} miles<br>
    Estimated Cost: $${best.estimatedCost.toFixed(2)}
  </div>`;

  candidates.forEach((s, i) => {
    html += `<div class="box">
      <b>#${i + 1}</b> ${s.store} - ${s.city}, ${s.state}<br>
      Price: $${s.price.toFixed(3)}<br>
      Approx Route Mile: ${s.mile.toFixed(0)}<br>
      Off Route: ${s.off.toFixed(1)} miles<br>
      Buy Gallons: ${fmtGallons(s.recommendedBuy)}<br>
      Coverage After Fuel: ${s.coverageAfterFuel.toFixed(0)} miles<br>
      Score: ${s.score.toFixed(3)}
    </div>`;
  });

  document.getElementById('output').innerHTML = html;
}

async function runAppTest() {
  const results = [];
  try {
    await loadFleet();
    results.push({ name: 'Fleet load', ok: trucks.length > 0, info: `${trucks.length} trucks loaded` });
  } catch (e) {
    results.push({ name: 'Fleet load', ok: false, info: e.message });
  }

  results.push({ name: 'CSV loaded', ok: fuelStops.length > 0, info: fuelStops.length ? `${fuelStops.length} stops loaded` : 'Upload Loves CSV first' });

  const selectedTruck = trucks.find(t => t.name === document.getElementById('truck').value);
  const hasTrip =
    document.getElementById('outboundStops').value.trim() ||
    document.getElementById('repositionStops').value.trim() ||
    document.getElementById('returnStops').value.trim();

  if (selectedTruck && hasTrip) {
    try {
      const trip = await buildSettlementRoute(selectedTruck);
      results.push({ name: 'Route build', ok: !!trip && route.length > 0, info: route.length ? `${route.length} route points` : 'No route points' });
      results.push({ name: 'Map render', ok: route.length > 0, info: route.length ? 'Map drawn' : 'Map empty' });
      results.push({ name: 'ETA compute', ok: totalDurationHours > 0, info: totalDurationHours > 0 ? fmtHours(totalDurationHours) : 'No ETA' });
    } catch (e) {
      results.push({ name: 'Route build', ok: false, info: e.message });
    }
  } else {
    results.push({ name: 'Route build', ok: false, info: 'Select truck and enter trip stops' });
  }

  let html = `<div class="box"><b>App Test Results</b><br>`;
  results.forEach(r => {
    html += `<div><span class="${r.ok ? 'ok' : 'bad'}">${r.ok ? 'PASS' : 'FAIL'}</span> — ${r.name}: ${r.info}</div>`;
  });
  html += `</div>`;
  document.getElementById('testPanel').innerHTML = html;
}
</script>
</body>
</html>
