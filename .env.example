PORT=3100
HOST=0.0.0.0

# Optional: require this secret on fuel writes + Relay file import/confirm/undo (header X-IH35-ERP-Secret or Authorization: Bearer …).
# Leave unset for local dev. In production, set a long random value and paste the same value once in the Fuel page “ERP write key” box (stored in browser localStorage only).
# ERP_WRITE_SECRET=

# PostgreSQL (Render: Internal Database URL on the Postgres service, or External URL for your laptop)
# Required for TMS loads/fleet tables. Also enables maintenance_service_catalog (service-type picker; seeded on server start).
# On every server start (when DATABASE_URL is set), `initializeDatabase()` in server startup runs
# `lib/ensure-app-database-objects.mjs` — CREATE IF NOT EXISTS only (no drops / no ALTER): merge_log, dedup_skipped,
# rename_log, driver_system_links, canonical_names, integrity_alerts (PG mirror), scheduled_reports, company_settings,
# erp_fleet_defaults, service_types, vehicle_maintenance_schedules, vehicle_parts_reference, plus schema_migrations.
# Logs CRITICAL if any of the ten dedupe/support tables are still missing after DDL (check earlier ensure failed lines).
# Full seed data: npm run db:migrate (run once per database, then redeploy or restart so the app re-reads state).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Local Postgres: set DATABASE_SSL=false
DATABASE_SSL=false

# Geocode + autocomplete (recommended on Render). Improves stop search and Auto miles.
# Without it, OpenStreetMap Nominatim is used (~1 geocode/sec); multi-stop Auto miles will pause between stops.
GEOAPIFY_API_KEY=

# PC*Miler / Trimble Maps — practical miles for TMS Auto miles + settlement (Authorization header value from Trimble).
# https://developer.trimblemaps.com/restful-apis/routing/route-reports/post-route-reports
# PCMILER_API_KEY=
# PCMILER_DATA_VERSION=Current

# QuickBooks Online: background refresh of vendor/item/account cache (minutes). Min 5.
# QBO_AUTO_SYNC_MINUTES=360
# Dispatch: re-read cached QBO JSON from disk on this interval (GET /api/qbo/catalog only; no Intuit call). 0 = off.
# QBO_CATALOG_UI_POLL_MINUTES=30
# Minor version for attachment uploads (invoice file sync from load documents). Default 65.
# QBO_MINOR_VERSION=65

# Pull recent Bills, Purchases, VendorCredits, Invoices from QBO into local cache for Reports (0 = disable txn sync).
# QBO_SYNC_TRANSACTION_DAYS=90

# Maintenance hub: GET /api/qbo/sync-alerts only considers maintenance/AP/WO rows in this many days (default 120, max 366).
# QBO_SYNC_ALERT_LOOKBACK_DAYS=120

# Maintenance: integrity alerts (parts frequency, tire interval, fuel gallons vs miles). All optional.
# SECURITY_ALERT_WINDOW_DAYS=30
# SECURITY_FUEL_PURCHASE_RATIO=1.22
# SECURITY_DEFAULT_MPG=6.5
# SECURITY_MAX_REPAIRS_7D=6
# SECURITY_TIRE_MIN_INTERVAL_MI=38000
# SECURITY_HIGH_COST_SINGLE=7500

# Driver-risk alerts (damage / accident patterns on a unit; driver name from Samsara assignments when available).
# DRIVER_RISK_WINDOW_DAYS=30
# DRIVER_RISK_MIN_EVENTS=4
# DRIVER_RISK_ACCIDENT_WINDOW_DAYS=90
# DRIVER_RISK_MAX_ACCIDENTS=2

# Yard geofence + idle snapshot (GET /api/tracking/idle-snapshot) — T120–T178; default center is approximate for Mines Rd, Laredo.
# YARD_LABEL=21918 Mines Rd, Laredo, TX
# YARD_LAT=27.65138
# YARD_LON=-99.62903
# YARD_RADIUS_M=2000
# Rough opportunity cost when TMS shows days since last completed load but no active trip (for investigation only).
# IDLE_EST_DAILY_REVENUE=800

# Unified analytics for scripts / IDE extensions: GET /api/analytics/fleet-inconsistencies

# QuickBooks Online — bank account used on Purchase/Expense (matches banking downloads). Class per unit = QBO Class name matching truck unit (e.g. T160).
# DEFAULT_QBO_BANK_ACCOUNT_ID=
# Invoices from dispatch: prefer a Service item named "Line haul" in QBO (after catalog sync), or set an explicit id:
# DEFAULT_QBO_LINEHAUL_ITEM_ID=
# DEFAULT_QBO_INVOICE_ITEM_ID=

# Next suggested load / invoice # = max(existing numeric load #, DEFAULT_NEXT_LOAD_NUMBER-1)+1. Example first load 13501:
# DEFAULT_NEXT_LOAD_NUMBER=13501

# Optional: driver settlement UI shows suggested pay = this fraction of trip revenue per load (0–1).
# DRIVER_SETTLEMENT_PAY_PCT=0.82

# IFTA / fuel tax (roadmap): combine jurisdiction miles (ELD/GPS, e.g. Samsara) with fuel gallons by state (fuel card CSV
# and/or QuickBooks-coded fuel purchases). Quarterly filing + 4-year retention are typical; see Reports → IFTA & compliance in the ERP UI.

# PDF headers (trip sheet, invoice, settlements) — company name on the blue band; address and phone optional.
# TMS_COMPANY_NAME=IH35 Transportation, LLC
# TMS_COMPANY_ADDRESS=1122 Black Diamond\nLaredo, TX 78045
# TMS_COMPANY_PHONE=(555) 000-0000
# Trip invoice (Always Track–style PDF): payment due = invoice date + N days; terms label; optional footer (use \n for lines).
# TMS_INVOICE_PAYMENT_TERMS_DAYS=30
# TMS_INVOICE_TERMS=Regular Pay
# TMS_INVOICE_FOOTER_NOTES=All payments must be assigned and sent to:\nYour factor / bank block here
# TMS_PDF_FOOTER_URL=www.example.com
# Driver settlement PDF: default $/mi shown when pay % is set but you want a display rate (optional).
# DRIVER_PDF_DEFAULT_MILE_RATE=0.40

# --- ERP user accounts (optional; when data/app-users.json has users, API calls need Authorization: Bearer <token> from Settings) ---
# `npm run qa:isolated` sets IH35_SMOKE_GATE=1 on its ephemeral child server only so scripts/system-smoke.mjs JSON GETs pass without a session. Do not set IH35_SMOKE_GATE on a long-lived production listener.
# IH35_AUTH_SECRET=long-random-string-for-session-tokens
# IH35_REQUIRE_AUTH=1
# First admin auto-created on server start when no users file yet (password 8+ chars):
# IH35_BOOTSTRAP_ADMIN_EMAIL=admin@yourfleet.com
# IH35_BOOTSTRAP_ADMIN_PASSWORD=

# Reports → Team & security: idle thresholds for ERP users (last API activity / login). Critical ≥ warn.
# TEAM_ACTIVITY_WARN_DAYS=7
# TEAM_ACTIVITY_CRITICAL_DAYS=14

# Samsara: use a token with Fleet + Vehicle Stats; for Safety/HOS also enable "Read ELD Compliance Settings (US)".
# Read fleet + driver search (Lists & catalogs → Vendors & drivers: GET /api/integrations/samsara/drivers) use SAMSARA_API_TOKEN.
# IFTA tabular report (GET /api/reports/fuel/ifta) calls GET /fleet/reports/ifta/vehicle — token needs Read IFTA (US) scope in Samsara Cloud.
# For ERP → Samsara PATCH (Lists & catalogs → Fleet & Samsara, POST /api/integrations/samsara/vehicle|driver/:id),
# set SAMSARA_WRITE_API_TOKEN with Write Vehicles + Write Drivers (https://developers.samsara.com/docs/authentication). If unset, writes fall back to SAMSARA_API_TOKEN.
# Vehicle list returns identity fields when available from telematics (e.g. VIN, license plate, engine serial / ESN — see Samsara API changelog).
SAMSARA_API_TOKEN=REPLACE_WITH_NEW_TOKEN
# SAMSARA_WRITE_API_TOKEN=
ALLOWED_ORIGIN=*
DEFAULT_RESERVE_GALLONS=35
DEFAULT_MAX_DETOUR_MILES=10
DEFAULT_TARGET_SHIFT_MILES=750
DEFAULT_PERSONAL_CONVEYANCE_MILES=45
DEFAULT_FILL_TARGET_GALLONS=120

# --- External TMS / integrations ---
# Alvys Public API (Bearer JWT from Alvys developer portal). Default host: https://integrations.alvys.com
# Docs: https://docs.alvys.com
# ALVYS_API_TOKEN=
# ALVYS_API_BASE_URL=https://integrations.alvys.com
# ALVYS_API_VERSION=1

# All-Ways Track (or similar): use only if your vendor gives a REST base URL + token. No standard public API is assumed.
# ALWAYS_TRACK_API_BASE_URL=
# ALWAYS_TRACK_API_KEY=
# ALWAYS_TRACK_HEALTH_PATH=/health
